- name: Configurar servidor web con Apache
  hosts: webserver
  become: yes
  tasks:
    - name: Instalar Apache
      apt:
        name: apache2
        state: present
        update_cache: yes

    - name: Copiar página de inicio personalizada
      copy:
        dest: /var/www/html/index.html
        content: "<h1>Servidor web automatizado con Ansible</h1>"

    - name: Asegurar que Apache esté activo
      service:
        name: apache2
        state: started
        enabled: yes
